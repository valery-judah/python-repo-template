[build-system]
requires = ["hatchling>=1.27.0"]
build-backend = "hatchling.build"

[project]
name = "{{ repo_slug }}"
version = "0.1.0"
description = "There should be description of your project."
readme = "README.md"
requires-python = ">={{ python_version }}"
dependencies = [
  "pydantic>=2,<3",
]

[dependency-groups]
dev = [
  "poethepoet>=0.32,<1",
  "pyright>=1.1.408",
  "pytest>=8.4.0",
  "ruff>=0.12.0",
]

[project.scripts]
"{{ package_name }}" = "{{ package_name }}.cli:main"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP"]

[tool.pyright]
pythonVersion = "{{ python_version }}"
venvPath = "."
venv = ".venv"
typeCheckingMode = "strict"
reportMissingTypeStubs = false
reportUnnecessaryTypeIgnoreComment = "warning"
include = ["src", "tests", "scripts/clean.py"]
exclude = [
  ".venv",
  ".venv/**",
  ".venv-*",
  ".venv-*/**",
  "**/.venv",
  "**/.venv/**",
  "**/.venv-*",
  "**/.venv-*/**",
  "**/node_modules",
  "**/__pycache__",
  "**/.*",
  ".pytest_cache",
  ".ruff_cache",
  ".mypy_cache",
  ".pyright",
  "build",
  "dist",
]
executionEnvironments = [
  { root = ".", extraPaths = ["src"] },
]

[tool.pytest.ini_options]
addopts = "-q"
testpaths = ["tests"]

[tool.poe]
include = "poe_tasks.toml"
