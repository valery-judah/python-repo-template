.DEFAULT_GOAL := help

.PHONY: ensure-uv help sync init lock install add-rich fmt lint type test check secret-scan secret-scan-staged install-git-hooks run
ensure-uv:
	@command -v uv >/dev/null 2>&1 || { \
		echo "Error: 'uv' is not installed or not on PATH."; \
		echo "Install with: curl -LsSf https://astral.sh/uv/install.sh | sh"; \
		exit 127; \
	}

help: ## Show this help message
	@echo "Usage: make <target>"
	@echo ""
	@echo "Targets:"
	@awk 'BEGIN {FS = ":.*?## "} /^[a-zA-Z_-]+:.*?## / {printf "  %-20s %s\n", $$1, $$2}' $(MAKEFILE_LIST) | sort

sync: ensure-uv ## Sync dependencies using uv (creates/updates lockfile)
	uv sync

init: sync install ## Bootstrap local dev environment

lock: ensure-uv ## Generate or refresh uv.lock
	uv lock

install: sync ## Install the package in editable mode
	uv pip install --editable .

add-rich: ensure-uv ## Add `rich` dependency via uv (updates pyproject + uv.lock)
	uv add rich
	uv sync

fmt: ensure-uv ## Format and auto-fix lint issues
	uv run ruff format .
	uv run ruff check . --fix

lint: ensure-uv ## Run lint checks
	uv run ruff format . --check
	uv run ruff check .

type: ensure-uv ## Run static type checks
	uv run mypy src

test: install ## Run unit tests
	uv run pytest tests

check: fmt lint type test ## Run all checks

secret-scan: ## Scan tracked repository files for leaked Gemini API keys
	@PYTHONPATH=src uv run python -m {{ package_name }}.devtools.secret_scan --scope repo

secret-scan-staged: ## Scan staged added lines for leaked Gemini API keys
	@PYTHONPATH=src uv run python -m {{ package_name }}.devtools.secret_scan --scope staged-added

install-git-hooks: ## Configure git to use repo-managed hooks
	git config core.hooksPath .githooks

run: install ## Run {{ package_name }} demo CLI
	uv run python -m {{ package_name }}.cli
